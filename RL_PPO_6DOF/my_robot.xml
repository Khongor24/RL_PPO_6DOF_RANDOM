<mujoco model="simple_arm">
    <compiler angle="degree"/>

    <option gravity="0 0 0"/>

    <worldbody>
        <light pos="0 0 3"/>

        <geom
            name="floor"
            type="plane"
            size="5 5 0.1"
            rgba="0.8 0.8 0.8 1"
        />

        <!-- Purple rectangle outline marking reachable target area (0.6x0.6 centered at 0.55, 0) -->
        <!-- Bottom edge: X from 0.25 to 0.85, Y=-0.3 -->
        <geom
            name="area_edge_bottom"
            type="capsule"
            fromto="0.25 -0.3 0.1 0.85 -0.3 0.1"
            size="0.01"
            rgba="0.8 0 0.8 1"
            contype="0"
            conaffinity="0"
        />
        <!-- Top edge: X from 0.25 to 0.85, Y=0.3 -->
        <geom
            name="area_edge_top"
            type="capsule"
            fromto="0.25 0.3 0.1 0.85 0.3 0.1"
            size="0.01"
            rgba="0.8 0 0.8 1"
            contype="0"
            conaffinity="0"
        />
        <!-- Left edge: Y from -0.3 to 0.3, X=0.25 -->
        <geom
            name="area_edge_left"
            type="capsule"
            fromto="0.25 -0.3 0.1 0.25 0.3 0.1"
            size="0.01"
            rgba="0.8 0 0.8 1"
            contype="0"
            conaffinity="0"
        />
        <!-- Right edge: Y from -0.3 to 0.3, X=0.85 -->
        <geom
            name="area_edge_right"
            type="capsule"
            fromto="0.85 -0.3 0.1 0.85 0.3 0.1"
            size="0.01"
            rgba="0.8 0 0.8 1"
            contype="0"
            conaffinity="0"
        />

        <!-- Green target marker (free body so it can move) -->
        <body name="target" pos="0.55 0 0.1">
            <joint name="target_free" type="free"/>
            <geom
                name="target_marker"
                type="sphere"
                size="0.05"
                rgba="0 1 0 1"
                contype="0"
                conaffinity="0"
            />
        </body>

        <!-- Robot base -->
        <body name="base" pos="0 0 0.4">
            <geom
                name="base_geom"
                type="sphere"
                size="0.08"
                rgba="0.4 0.4 0.4 1"
            />

            <body name="link1" pos="0 0 0">
                <joint name="joint1" type="hinge" axis="0 0 1"
                       range="-90 90" damping="1.0" armature="0.1"/>
                <geom name="link1_geom" type="capsule"
                      fromto="0 0 0 0.35 0 0" size="0.04"
                      rgba="0.2 0.2 1 1"/>

                <body name="link2" pos="0.35 0 0">
                    <joint name="joint2" type="hinge" axis="0 -1 0"
                           range="-90 90" damping="1.0" armature="0.1"/>
                    <geom name="link2_geom" type="capsule"
                          fromto="0 0 0 0.3 0 0" size="0.035"
                          rgba="1 0.6 0.2 1"/>

                    <body name="link3" pos="0.3 0 0">
                        <joint name="joint3" type="hinge" axis="0 0 1"
                               range="-90 90" damping="0.8" armature="0.1"/>
                        <geom name="link3_geom" type="capsule"
                              fromto="0 0 0 0.25 0 0" size="0.03"
                              rgba="0.8 0.2 0.8 1"/>

                        <body name="link4" pos="0.25 0 0">
                            <joint name="joint4" type="hinge" axis="0 -1 0"
                                   range="-90 90" damping="0.6" armature="0.1"/>
                            <geom name="link4_geom" type="capsule"
                                  fromto="0 0 0 0.2 0 0" size="0.025"
                                  rgba="0.2 0.8 0.8 1"/>

                            <!-- link5 -->
                            <body name="link5" pos="0.2 0 0">
                                <joint name="joint5" type="hinge" axis="0 0 1"
                                       range="-90 90" damping="0.5" armature="0.08"/>
                                <geom name="link5_geom" type="capsule"
                                      fromto="0 0 0 0.15 0 0" size="0.02"
                                      rgba="0.8 0.8 0.2 1"/>

                                <!-- link6 -->
                                <body name="link6" pos="0.15 0 0">
                                    <joint name="joint6" type="hinge" axis="0 -1 0"
                                           range="-90 90" damping="0.4" armature="0.05"/>
                                    <geom name="link6_geom" type="capsule"
                                          fromto="0 0 0 0.1 0 0" size="0.015"
                                          rgba="0.2 0.8 0.2 1"/>

                                    <!-- Red tip -->
                                    <body name="tip" pos="0.1 0 0">
                                        <geom name="tip_geom" type="sphere"
                                              size="0.04" rgba="1 0 0 1"
                                              contype="0" conaffinity="0"/>
                                    </body>
                                </body>
                            </body>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <motor name="motor1" joint="joint1" gear="10"
               ctrllimited="true" ctrlrange="-1 1"/>
        <motor name="motor2" joint="joint2" gear="6"
               ctrllimited="true" ctrlrange="-1 1"/>
        <motor name="motor3" joint="joint3" gear="4"
               ctrllimited="true" ctrlrange="-1 1"/>
        <motor name="motor4" joint="joint4" gear="3"
               ctrllimited="true" ctrlrange="-1 1"/>
        <motor name="motor5" joint="joint5" gear="2"
               ctrllimited="true" ctrlrange="-1 1"/>
        <motor name="motor6" joint="joint6" gear="1.5"
               ctrllimited="true" ctrlrange="-1 1"/>
    </actuator>
</mujoco>